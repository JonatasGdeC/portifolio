<section class="content-section" id="about">
    <div class="section-heading">
        <h2>@Localizer[name: "AboutTitle"]</h2>
        <span></span>
    </div>

    <p class="section-copy">
        @Localizer[name: "AboutCopy"]
    </p>

    <div class="skills-grid">
        <article class="skill-card">
            <h3>@Localizer[name: "SkillFrontend"]</h3>
            <p>@Localizer[name: "SkillFrontendCopy"]</p>
        </article>

        <article class="skill-card">
            <h3>@Localizer[name: "SkillBackend"]</h3>
            <p>@Localizer[name: "SkillBackendCopy"]</p>
        </article>

        <article class="skill-card">
            <h3>@Localizer[name: "SkillOthers"]</h3>
            <p>@Localizer[name: "SkillOthersCopy"]</p>
        </article>
    </div>
</section>