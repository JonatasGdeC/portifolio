@using Portifolio.Web.Models

<section class="content-section" id="work">
    <div class="section-heading">
        <h2>@Localizer[name: "WorkTitle"]</h2>
        <span></span>
    </div>

    <p class="section-copy">
        @Localizer[name: "WorkCopy"]
    </p>

    <div class="projects-grid">
        @foreach (ProjectModel project in Projects)
        {
            <button class="project-card" type="button" @onclick="() => OpenProject(project: project)">
                <div class="project-thumbnail">
                    @if (project.Studies)
                    {
                        <span class="study-badge">Estudos</span>
                    }
                    
                    @if (project.Images.Count > 0)
                    {
                        <img src="@GetThumbnailUrl(project: project)" alt="@project.Title"/>
                    }
                </div>

                <div class="project-meta">
                    <h3>@project.Title</h3>
                    <p>@project.Summary</p>
                </div>
            </button>
        }
    </div>
</section>

@if (SelectedProject is not null)
{
    <div class="project-modal-backdrop" role="presentation" @onclick="CloseProject">
        <section class="project-modal" role="dialog" aria-modal="true" aria-labelledby="project-modal-title" @onclick:stopPropagation>
            <button class="modal-close" type="button" aria-label="Fechar modal" @onclick="CloseProject">x</button>

            <div class="project-carousel" aria-label="Imagens do projeto">
                <button class="carousel-control" type="button" aria-label="Imagem anterior" @onclick="PreviousImage">&lt;</button>

                <div class="carousel-frame">
                    @if (SelectedProject.Images.Count > 0)
                    {
                        <button class="carousel-image-button"
                                type="button"
                                aria-label="Ampliar imagem @(ActiveImageIndex + 1)"
                                @onclick="OpenImageModal">
                            <img class="carousel-image"
                                 src="@GetImageUrl(project: SelectedProject, imageIndex: ActiveImageIndex)"
                                 alt="@($"{SelectedProject.Title} - imagem {ActiveImageIndex + 1}")" />
                        </button>
                    }
                </div>

                <button class="carousel-control" type="button" aria-label="Proxima imagem" @onclick="NextImage">&gt;</button>
            </div>

            <div class="carousel-dots" aria-label="Selecionar imagem">
                @for (int index = 0; index < SelectedProject.Images.Count; index++)
                {
                    int imageIndex = index;
                    <button class="@(ActiveImageIndex == imageIndex ? "dot active" : "dot")"
                            type="button"
                            aria-label="Mostrar imagem @(imageIndex + 1)"
                            @onclick="() => SetImage(imageIndex: imageIndex)">
                    </button>
                }
            </div>

            <div class="modal-content">
                <p class="modal-kicker">@SelectedProject.Category</p>
                <h3 id="project-modal-title">@SelectedProject.Title</h3>
                <p class="modal-description">@SelectedProject.Description</p>

                <div class="tools-list" aria-label="Ferramentas utilizadas">
                    @foreach (string tool in SelectedProject.Tools)
                    {
                        <span>@tool</span>
                    }
                </div>

                <div class="project-links">
                    @if (!string.IsNullOrWhiteSpace(value: SelectedProject.Links.Production))
                    {
                        <a href="@SelectedProject.Links.Production" target="_blank" rel="noreferrer">Acesse aqui</a>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(value: SelectedProject.Links.FrontendGithub))
                    {
                        <a href="@SelectedProject.Links.FrontendGithub" target="_blank" rel="noreferrer">Frontend</a>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(value: SelectedProject.Links.BackendGithub))
                    {
                        <a href="@SelectedProject.Links.BackendGithub" target="_blank" rel="noreferrer">Backend</a>
                    }
                </div>
            </div>
        </section>
    </div>

    @if (IsImageModalOpen && SelectedProject.Images.Count > 0)
    {
        <div class="image-modal-backdrop" role="presentation" @onclick="CloseImageModal">
            <section class="image-modal" role="dialog" aria-modal="true" aria-label="Imagem ampliada do projeto" @onclick:stopPropagation>
                <button class="modal-close image-modal-close" type="button" aria-label="Fechar imagem ampliada" @onclick="CloseImageModal">x</button>

                <div class="image-carousel" aria-label="Carrossel de imagens ampliadas">
                    <button class="carousel-control image-carousel-control" type="button" aria-label="Imagem anterior" @onclick="PreviousImage">&lt;</button>

                    <div class="image-carousel-frame">
                        <img class="image-modal-image"
                             src="@GetImageUrl(project: SelectedProject, imageIndex: ActiveImageIndex)"
                             alt="@($"{SelectedProject.Title} - imagem ampliada {ActiveImageIndex + 1}")" />
                    </div>

                    <button class="carousel-control image-carousel-control" type="button" aria-label="Proxima imagem" @onclick="NextImage">&gt;</button>
                </div>

                <div class="image-modal-footer">
                    <div class="carousel-dots image-carousel-dots" aria-label="Selecionar imagem ampliada">
                        @for (int index = 0; index < SelectedProject.Images.Count; index++)
                        {
                            int imageIndex = index;
                            <button class="@(ActiveImageIndex == imageIndex ? "dot active" : "dot")"
                                    type="button"
                                    aria-label="Mostrar imagem ampliada @(imageIndex + 1)"
                                    @onclick="() => SetImage(imageIndex: imageIndex)">
                            </button>
                        }
                    </div>

                    <span class="image-counter">@(ActiveImageIndex + 1) / @SelectedProject.Images.Count</span>
                </div>
            </section>
        </div>
    }
}
