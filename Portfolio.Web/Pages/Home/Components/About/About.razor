<section class="content-section" id="about">
    <div class="section-heading">
        <h2>@Localizer[name: "AboutTitle"]</h2>
        <span></span>
    </div>

    <p class="section-copy">
        @Localizer[name: "AboutCopy"]
    </p>

    <div class="skills-grid">

        <article class="skill-card">
            <h3>@Localizer[name: "SkillFrontend"]</h3>

            <ul class="tools-list">
                @foreach (string tool in _frontEndSkills)
                {
                    <li>@tool</li>
                }
            </ul>
        </article>

        <article class="skill-card">
            <h3>@Localizer[name: "SkillBackend"]</h3>

            <ul class="tools-list">
                @foreach (string tool in _backendSkills)
                {
                    <li>@tool</li>
                }
            </ul>
        </article>

        <article class="skill-card">
            <h3>Cloud & DevOps</h3>

            <ul class="tools-list">
                @foreach (string tool in _devOpsSkills)
                {
                    <li>@tool</li>
                }
            </ul>
        </article>

        <article class="skill-card">
            <h3>@Localizer[name: "SkillArchitecture"]</h3>

            <ul class="tools-list">
                @foreach (string tool in _architectureSkills)
                {
                    <li>@tool</li>
                }
            </ul>
        </article>

    </div>
</section>